{
  "plugins": ["./scripts/stylelint-vaak-tokens.cjs"],
  "rules": {
    "vaak-tokens/no-raw-color": [true, { "severity": "warning" }],
    "vaak-tokens/no-raw-spacing": [true, { "severity": "warning" }],
    "vaak-tokens/no-raw-font-size": [true, { "severity": "warning" }],
    "vaak-tokens/no-raw-radius": [true, { "severity": "warning" }],
    "vaak-tokens/no-raw-z-index": [true, { "severity": "warning" }],
    "vaak-tokens/no-disable-without-justification": [true, { "severity": "error" }]
  },
  "ignoreFiles": [
    "dist/**",
    "node_modules/**",
    "src-tauri/target/**"
  ]
}
