{
  "extends": ["stylelint-config-standard"],
  "plugins": ["./scripts/stylelint-vaak-tokens.cjs"],
  "rules": {
    "vaak-tokens/no-raw-color": "warning",
    "vaak-tokens/no-raw-spacing": "warning",
    "vaak-tokens/no-raw-font-size": "warning",
    "vaak-tokens/no-raw-radius": "warning",
    "vaak-tokens/no-raw-z-index": "warning",
    "vaak-tokens/no-disable-without-justification": "error"
  },
  "ignoreFiles": [
    "dist/**",
    "node_modules/**",
    "src-tauri/target/**"
  ]
}
