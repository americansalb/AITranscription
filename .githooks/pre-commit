    subset of the plan's <!-- scope: path1 path2 ... --> block, or
    unrestricted if the block is `* ` ([staged_outside_scope]).
  - phase == "execution" + no plan → allow (back-compat / opt-out path).

Bypass via `git commit --no-verify`. Note (per spec §103): standard git does
NOT record --no-verify in commit metadata, so there is no reliable post-hoc
detection of bypass. Marker-file mechanism deferred to v1.5.3.

Implementation language is Python (platform-engineer msg 985 F1, option b):
stdlib only — `json`, `hashlib`, `subprocess`, `re` — works on every dev
machine that has the Vaak backend (Python ≥3.x). git-for-Windows ships with
MSYS bash and dispatches the shebang to `python3` on PATH; Microsoft-Store
Python users may need to install python.org Python or alias `python3`.

Exit codes: 0 = allow commit, 1 = reject commit (git aborts the commit).
"""

import hashlib
import json
import os
import sys

# DISABLED per human msg 1826 (2026-05-23). All plan-scope / plan-hash / phase
# gating turned off. Hook always passes. Remove this `sys.exit(0)` to re-enable.
sys.exit(0)
import re
import subprocess
import sys
from pathlib import Path


def repo_root() -> Path:
    """Resolve git toplevel from cwd (works whether the hook is invoked from
    a subdirectory or the repo root)."""
    try:
        out = subprocess.check_output(
            ["git", "rev-parse", "--show-toplevel"], stderr=subprocess.DEVNULL
        )
        return Path(out.decode().strip())
    except subprocess.CalledProcessError:
        # Not in a git repo — defensive; git wouldn't run hooks in this case.
        return Path.cwd()


def read_active_section(root: Path) -> str:
    """Read .vaak/active-section marker (commit A.2 collab.rs writer). Falls
    back to "default" if absent or empty — matches read_active_section_marker
    in collab.rs."""
    marker = root / ".vaak" / "active-section"
    try:
        slug = marker.read_text(encoding="utf-8").strip()
        return slug if slug else "default"
    except OSError:
        return "default"


def protocol_path_for_section(root: Path, section: str) -> Path:
    """Mirror of vaak-mcp.rs protocol_path_for_section."""
    if section == "default":
        return root / ".vaak" / "protocol.json"
    return root / ".vaak" / "sections" / section / "protocol.json"


def parse_scope_block(plan_text: str):
    """Mirror of vaak-mcp.rs parse_scope_block. Returns:
      - None         → no <!-- scope: ... --> block found.
      - []           → `* ` unrestricted scope.
      - [str, ...]   → declared scope paths."""
    m = re.search(r"<!--\s*scope:\s*([^>]*?)\s*-->", plan_text)
    if not m:
        return None
    body = m.group(1).strip()
    if body == "*" or body == "":
        return []
    return body.split()


def parse_delegation_blocks(plan_text: str):
    """Commit H — Python mirror of main.rs parse_delegation_blocks (Commit D
    0a9fcb1). Uses the same non-greedy grammar pinned in spec line 102 +
    platform-eng msg 1916 #2. Returns list of dicts; each dict has keys
    'owner', 'section', and optional 'deadline' / 'deps'. Malformed blocks
    are silently dropped here (lenient parser used for collection; the
    duplicate-detection + owner-validation steps in main() enforce the
    well-formedness gate per spec line 115-116).

    Cross-language parity with the Rust parser is the v1.6 corpus test
    surface (dev-challenger msg 1939 #4); for v1 the two parsers share
    the same grammar by spec convention."""
    blocks = []
    for m in re.finditer(r"<!--\s*delegation:\s*(.+?)\s*-->", plan_text, re.DOTALL):
        body = m.group(1).strip()
        entry = {}
        for tok in body.split():
            if "=" not in tok:
                continue
            k, v = tok.split("=", 1)
            if k == "owner":
                entry["owner"] = v
            elif k == "section":
                entry["section"] = v
            elif k == "deadline":
                entry["deadline"] = v
            elif k == "deps":
                entry["deps"] = [d.strip() for d in v.split(",") if d.strip()]
            # Unknown keys silently dropped (forward-compat).
        if "owner" in entry and "section" in entry:
            blocks.append(entry)
        # Else: missing required fields — silently drop (matches Rust
        # lenient parser). Strict-mode error reporting happens in the
        # well-formedness validator below.
    return blocks


def read_team_status_seats(root: Path) -> set:
    """Read .vaak/project.json + .vaak/sessions.json to build the set of
    known team seat slugs (role:instance form) for delegation-owner
    validation per spec line 116.

    Commit 14 (evil-arch msg 2045 CRITICAL #1, human msg 2055 patch
    authorization): fail-CLOSED on JSON corruption. Previous behavior
    returned an empty set on json.JSONDecodeError, which caused the
    delegation_owner_unknown gate to be silently SKIPPED. The two-
    controls integrity contract depends on team_status being
    authoritative — a corrupt project.json should block commits with
    a clear error, not bypass gates.

    Missing file → return empty set (back-compat for fresh checkouts
    that haven't run any Vaak roles yet; downstream validator skips
    the gate when known_seats is empty AND the project.json file
    doesn't exist — distinguished from corrupt-JSON).

    Corrupt file → raise via reject(); caller-side handling not needed.

    A seat is 'known' if it appears in project.json:roles[*] regardless of
    active status."""
    seats = set()
    project_path = root / ".vaak" / "project.json"
    if not project_path.exists():
        # Fresh checkout or pre-Vaak repo; back-compat empty set.
        return seats
    try:
        proj = json.loads(project_path.read_text(encoding="utf-8"))
    except OSError:
        # Transient I/O (file locked, permission, etc.) — fall back to
        # empty rather than blocking on infrastructure trouble. Same
        # defensive read as before; only JSON corruption is the new
        # fail-closed case.
        return seats
    except json.JSONDecodeError as e:
        reject(
            "project_state_unreadable",
            f".vaak/project.json is corrupt JSON: {e}. "
            "Integrity gates require parseable team state; fix the file before committing. "
            "(evil-arch msg 2045 CRITICAL #1 fail-closed gate)",
        )
    for role_entry in proj.get("roles", []) or []:
        role_slug = role_entry.get("slug")
        if not role_slug:
            continue
        max_instances = role_entry.get("max_instances") or role_entry.get("maxInstances") or 1
        try:
            n = max(int(max_instances), 1)
        except (TypeError, ValueError):
            n = 1
        for i in range(n):
            seats.add(f"{role_slug}:{i}")
    # Always-known: human:0 is the human-as-actor seat slug; explicitly
    # added so a plan can delegate to 'human:0' without needing a roles
    # entry for it.
    seats.add("human:0")
    return seats


def write_audit_marker(root: Path, plan_path: str, sections_touched: list) -> None:
    """Cooperative audit marker per spec line 119 (Commit H). Writes
    .vaak/last-pre-commit.json on every hook PASS so later review can ask
    'which sections were touched at this commit?' Best-effort — failure to
    write is non-fatal (audit is informational, not gating)."""
    marker = root / ".vaak" / "last-pre-commit.json"
    payload = {
        "ts": __import__("time").time() * 1000,
        "plan_path": plan_path,
        "sections_touched": sections_touched,
    }
    try:
        marker.write_text(json.dumps(payload, indent=2), encoding="utf-8")
    except OSError:
        # Audit-trail write failure is non-fatal — hook still allows commit.
        pass


def staged_files() -> list:
    """Files in the index, relative to repo root."""
    out = subprocess.check_output(
        ["git", "diff", "--cached", "--name-only"], stderr=subprocess.DEVNULL
    )
    return [line for line in out.decode().splitlines() if line.strip()]


def reject(code: str, msg: str) -> None:
    sys.stderr.write(f"[{code}] {msg}\n")
    sys.stderr.write(
        "\nBypass with `git commit --no-verify` (audit caveat: standard git does\n"
        "not record --no-verify in commit metadata; bypasses are not post-hoc\n"
        "auditable per spec §103).\n"
    )
    sys.exit(1)


def main() -> None:
    root = repo_root()
    section = read_active_section(root)
    proto_path = protocol_path_for_section(root, section)

    if not proto_path.exists():
        # No protocol state → no two-controls gate engaged. Allow commit.
        sys.exit(0)

    try:
        proto = json.loads(proto_path.read_text(encoding="utf-8"))
    except OSError as e:
        # Transient I/O (file locked, permission, vanished mid-read) —
        # warn + allow rather than blocking on infrastructure trouble.
        # Same defensive read as before for the I/O path.
        sys.stderr.write(
            f"[two-controls-hook] warning: could not read {proto_path} ({e}) — "
            "two-controls gate is OFF for this commit.\n"
        )
        sys.exit(0)
    except json.JSONDecodeError as e:
        # Commit 14 (evil-arch msg 2045 CRITICAL #1, human msg 2055 patch):
        # JSON corruption fails CLOSED. The two-controls integrity contract
        # depends on protocol.json being authoritative; a corrupt file
        # could mask phase=planning or plan_hash drift, letting commits
        # bypass gates silently. Prior behavior of "warn + exit 0" was a
        # silent integrity hole.
        reject(
            "protocol_state_unreadable",
            f"{proto_path} is corrupt JSON: {e}. "
            "Integrity gates require parseable protocol state; fix the file before "
            "committing (evil-arch msg 2045 CRITICAL #1 fail-closed gate).",
        )

    floor = proto.get("floor") or {}
    phase = floor.get("phase", "execution")

    if phase == "planning":
        reject(
            "planning_blocks_commit",
            f"Team is in planning phase for section '{section}'. accept_plan first "
            "before committing code.",
        )

    if phase != "execution":
        # Unknown phase — don't block but warn.
        sys.stderr.write(
            f"[two-controls-hook] warning: unknown phase '{phase}' — gate OFF.\n"
        )
        sys.exit(0)

    plan_path = floor.get("plan_path")
    plan_hash = floor.get("plan_hash")

    if not plan_path or not plan_hash:
        # No plan accepted → back-compat / opt-out path per spec §102. Allow.
        sys.exit(0)

    # plan_path is repo-relative under .vaak/design-notes/.
    plan_full = root / plan_path
    if not plan_full.exists():
        reject(
            "plan_path_missing",
            f"Accepted plan_path '{plan_path}' is missing on disk. "
            "Re-run accept_plan or open_planning to recover.",
        )

    # Verify plan_hash (a) — SHA-256 of plan file matches stored hash.
    actual_hash = hashlib.sha256(plan_full.read_bytes()).hexdigest()
    if actual_hash != plan_hash:
        reject(
            "plan_hash_mismatch",
            f"plan_path '{plan_path}' was edited since accept_plan. "
            f"Stored hash: {plan_hash[:16]}... Actual: {actual_hash[:16]}... "
            "Call protocol_mutate(revise_plan, ...) to re-bind the hash before "
            "committing (architect/manager/human only).",
        )

    # Verify scope block (b) — staged files are subset of declared scope.
    scope = parse_scope_block(plan_full.read_text(encoding="utf-8"))
    if scope is None:
        # accept_plan should have rejected this on the server side; defensive.
        reject(
            "plan_scope_block_missing",
            f"plan_path '{plan_path}' lacks <!-- scope: ... --> block. "
            "Use <!-- scope: * --> for unrestricted plans.",
        )

    if not scope:
        # Unrestricted * → scope check skipped. Delegation validation still
        # runs below (Commit H: plan-doc well-formedness independent of
        # file-scope discipline).
        _run_delegation_validation(root, plan_full, plan_path)
        write_audit_marker(root, plan_path, sections_touched=[])
        sys.exit(0)

    # Convert scope entries to a comparable set. Scope entries are exact paths
    # OR directory-prefix matches (path ending in "/"). Path normalization:
    # forward-slash form, no leading "./".
    def normalize(p: str) -> str:
        # Forward-slash form + strip a single leading "./" prefix.
        # `lstrip("./")` is character-set stripping (per tester msg 1147 catch)
        # which would corrupt dotfile names like `.gitignore` → `gitignore`.
        p2 = p.replace("\\", "/")
        return p2[2:] if p2.startswith("./") else p2

    scope_set = {normalize(p) for p in scope}
    # Glob normalization: scope entries ending with `/**` are equivalent to
    # the trailing-slash prefix form. Map `desktop/foo/**` → `desktop/foo/`
    # for the prefix check below. Closes the recurring --no-verify bypass
    # pattern this session (a5e96ea, 055d19a, 87893c8 + 7749369 all had to
    # bypass when architect used the `/**` glob form in revise_plan).
    # Per Instance #12 of the multi-writer ledger + dev-chall msg 396 F4 +
    # evil-arch msg 394 flag B + tech-leader msg 408 ruling.
    def to_prefix(p: str) -> str:
        # Trailing `/**` or `/*` → directory prefix.
        if p.endswith("/**"):
            return p[:-2]  # drop "**", keep trailing "/"
        if p.endswith("/*"):
            return p[:-1]  # drop "*", keep trailing "/"
        return p
    scope_set = {to_prefix(p) for p in scope_set}
    out_of_scope = []
    for staged in staged_files():
        s = normalize(staged)
        if s in scope_set:
            continue
        # Directory-prefix match: any scope entry ending with '/' allows
        # files under that directory.
        if any(p.endswith("/") and s.startswith(p) for p in scope_set):
            continue
        out_of_scope.append(staged)

    if out_of_scope:
        reject(
            "staged_outside_scope",
            f"Staged files outside the plan's declared scope:\n  "
            + "\n  ".join(out_of_scope)
            + f"\n\nDeclared scope from {plan_path}:\n  "
            + "\n  ".join(sorted(scope_set))
            + "\n\nEither (a) re-stage only in-scope files, or (b) call "
            "protocol_mutate(revise_plan, ...) to widen the plan's scope "
            "block (architect/manager/human only).",
        )

    # Scope check passed. Delegation well-formedness next (Commit H).
    sections_touched = _run_delegation_validation(root, plan_full, plan_path)
    write_audit_marker(root, plan_path, sections_touched=sections_touched)

    sys.exit(0)


def _run_delegation_validation(root: Path, plan_full: Path, plan_path: str) -> list:
    """Commit H — delegation-block well-formedness gate per spec lines
    108-119. Three classes of rejection:

      [delegation_drift]          duplicate section across blocks (plan
                                  doc has two blocks both claiming the
                                  same section ID — first-one-wins would
                                  silently mask the drift)
      [delegation_owner_unknown]  owner=X where X is not in team_status
                                  (typo guard; v1 uses
                                  project.json:roles[*] as the source of
                                  truth, not session liveness)
      [delegation_target_unmapped] a staged file contains
                                  <!-- delegation-target: section=Y -->
                                  but Y is not in the section-owner
                                  mapping

    NO committer-author identity check per architect msg 1909 #1 narrowing:
    single-machine git-config can't discriminate seats. Honor-system
    cooperative trail; the .vaak/last-pre-commit.json marker captures
    intent for post-hoc review.

    Returns the list of sections touched (intersection of staged-file
    delegation-target markers + the section-owner mapping) for the audit
    marker."""
    try:
        plan_text = plan_full.read_text(encoding="utf-8")
    except OSError:
        # Plan unreadable but scope check passed earlier — defensive: skip
        # delegation gate without blocking.
        return []

    blocks = parse_delegation_blocks(plan_text)
    if not blocks:
        # No <!-- delegation: --> blocks → nothing to validate. Allow.
        return []

    # 1. Duplicate-section detection — plan-doc drift.
    seen_sections = {}
    for entry in blocks:
        sec = entry["section"]
        if sec in seen_sections:
            reject(
                "delegation_drift",
                f"Plan '{plan_path}' has two delegation blocks for section "
                f"'{sec}': first owner={seen_sections[sec]}, second "
                f"owner={entry['owner']}. The proposal document is the "
                "source of truth — split the section or pick one owner.",
            )
        seen_sections[sec] = entry["owner"]

    # 2. Owner-in-team_status validation — typo guard.
    known_seats = read_team_status_seats(root)
    if known_seats:
        # Only validate when we successfully read project.json; if team
        # state is unreadable (transient I/O or fresh checkout), skip the
        # owner gate rather than block a commit on infrastructure trouble.
        unknown_owners = sorted(
            {entry["owner"] for entry in blocks if entry["owner"] not in known_seats}
        )
        if unknown_owners:
            reject(
                "delegation_owner_unknown",
                f"Plan '{plan_path}' delegates to seats not in "
                f".vaak/project.json:roles[*]:\n  "
                + "\n  ".join(unknown_owners)
                + "\n\nKnown seats (from project.json + human:0):\n  "
                + "\n  ".join(sorted(known_seats))
                + "\n\nFix the plan-doc owner=... value or add the role "
                "to project.json:roles[*].",
            )

    # 3. delegation-target marker validation (opt-in per spec line 117).
    #    Files self-tag with <!-- delegation-target: section=Y -->; if Y
    #    isn't in the section-owner mapping, reject. No target marker → no
    #    check (forward-compat for v1.X plan docs without target tagging).
    target_re = re.compile(r"<!--\s*delegation-target:\s*section=([^\s-][^\s]*)\s*-->")
    sections_touched = []
    for staged in staged_files():
        try:
            content = (root / staged).read_text(encoding="utf-8")
        except (OSError, UnicodeDecodeError):
            # Binary or unreadable file — skip target-marker check.
            continue
        for m in target_re.finditer(content):
            target_section = m.group(1)
            if target_section not in seen_sections:
                reject(
                    "delegation_target_unmapped",
                    f"Staged file '{staged}' declares "
                    f"<!-- delegation-target: section={target_section} --> "
                    f"but section '{target_section}' is not in the plan's "
                    f"delegation mapping. Either add a "
                    f"<!-- delegation: owner=... section={target_section} --> "
                    "block to the plan, or remove the target marker.",
                )
            if target_section not in sections_touched:
                sections_touched.append(target_section)

    return sections_touched


if __name__ == "__main__":
    main()
